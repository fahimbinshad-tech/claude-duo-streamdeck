{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.fahim.claude-duo",
  "Name": "Claude Duo Usage",
  "Version": "1.0.0.0",
  "Author": "Fahim Shad",
  "Description": "Live Claude Code usage (session + weekly + Fable) for both Claude accounts",
  "Category": "Claude Duo",
  "CategoryIcon": "imgs/category",
  "Icon": "imgs/plugin",
  "CodePath": "bin/plugin.js",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    }
  ],
  "Nodejs": {
    "Version": "20"
  },
  "Actions": [
    {
      "UUID": "com.fahim.claude-duo.personal",
      "Name": "Personal (gmail)",
      "Tooltip": "Claude usage for fahimbinshad@gmail.com",
      "Icon": "imgs/personal",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/usage-strip.json",
        "StackColor": "#F97316",
        "Icon": "imgs/personal",
        "TriggerDescription": {
          "Touch": "Open claude.ai usage",
          "Push": "Open claude.ai usage"
        }
      },
      "States": [
        {
          "Image": "imgs/key-personal"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.business",
      "Name": "Mi Assist (claude2)",
      "Tooltip": "Claude usage for fahim@miassist.ai",
      "Icon": "imgs/business",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/usage-strip.json",
        "StackColor": "#4ADE80",
        "Icon": "imgs/business",
        "TriggerDescription": {
          "Touch": "Open claude.ai usage",
          "Push": "Open claude.ai usage"
        }
      },
      "States": [
        {
          "Image": "imgs/key-business"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.sessions",
      "Name": "Claude Sessions",
      "Tooltip": "Live Claude Code sessions \u2014 tap to focus, twist to scroll",
      "Icon": "imgs/sessions",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/usage-strip.json",
        "StackColor": "#E07B54",
        "Icon": "imgs/sessions",
        "TriggerDescription": {
          "Touch": "Focus that session's window",
          "Rotate": "Scroll sessions",
          "Push": "Refresh"
        }
      },
      "States": [
        {
          "Image": "imgs/key-personal"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.skills",
      "Name": "Skills Dial",
      "Tooltip": "Twist through your top Claude skills, press to run in Warp",
      "Icon": "imgs/skills",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/usage-strip.json",
        "StackColor": "#E07B54",
        "Icon": "imgs/skills",
        "TriggerDescription": {
          "Touch": "Run selected skill",
          "Rotate": "Pick skill",
          "Push": "Run selected skill"
        }
      },
      "States": [
        {
          "Image": "imgs/key-personal"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.slack",
      "Name": "Slack Unread",
      "Tooltip": "Slack dock badge \u2014 tap to open Slack",
      "Icon": "imgs/slack",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/usage-strip.json",
        "StackColor": "#36C5F0",
        "Icon": "imgs/slack",
        "TriggerDescription": {
          "Touch": "Open Slack",
          "Push": "Open Slack"
        }
      },
      "States": [
        {
          "Image": "imgs/key-personal"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.whatsapp",
      "Name": "WhatsApp Unread",
      "Tooltip": "WhatsApp dock badge \u2014 tap to open WhatsApp",
      "Icon": "imgs/whatsapp",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/usage-strip.json",
        "StackColor": "#25D366",
        "Icon": "imgs/whatsapp",
        "TriggerDescription": {
          "Touch": "Open WhatsApp",
          "Push": "Open WhatsApp"
        }
      },
      "States": [
        {
          "Image": "imgs/key-personal"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.crm",
      "Name": "CRM Leads",
      "Tooltip": "Live leads from the miassist CRM board \u2014 tap opens the board or a lead, hold runs a Claude briefing",
      "Icon": "imgs/crm",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/usage-strip.json",
        "StackColor": "#4ADE80",
        "Icon": "imgs/crm",
        "TriggerDescription": {
          "Touch": "Open board / lead (hold = Claude briefing)",
          "Push": "Open highlighted lead",
          "Rotate": "Scroll leads"
        }
      },
      "States": [
        {
          "Image": "imgs/crm"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.crmlead",
      "Name": "CRM Lead Key",
      "Tooltip": "One key per lead (newest first, by key position) \u2014 press opens that lead on the board",
      "Icon": "imgs/crm-lead",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/crm-lead"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.skillkey",
      "Name": "Skill Key",
      "Tooltip": "One most-used skill per key (by key position) \u2014 press runs it in a fresh Warp tab",
      "Icon": "imgs/skills",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/skills"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.ads",
      "Name": "Ads Today",
      "Tooltip": "Today's spend, leads, and cost per lead per Meta ad account \u2014 tap opens that exact account in Ads Manager (read-only)",
      "Icon": "imgs/ads",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/usage-strip.json",
        "StackColor": "#E07B54",
        "Icon": "imgs/ads",
        "TriggerDescription": {
          "Touch": "Open that account in Ads Manager (hold = Claude status)",
          "Push": "Open Ads Manager"
        }
      },
      "States": [
        {
          "Image": "imgs/ads"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.adskey",
      "Name": "Ad Account Key",
      "Tooltip": "One ad account per key (by position) \u2014 press opens that exact account in Ads Manager",
      "Icon": "imgs/ads",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/ads"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.money",
      "Name": "Money \u00b7 Invoices",
      "Tooltip": "Every client invoice \u2014 who owes what and when it's due (read-only from GoHighLevel). Any press opens the invoices list",
      "Icon": "imgs/money",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/usage-strip.json",
        "StackColor": "#4ADE80",
        "Icon": "imgs/money",
        "TriggerDescription": {
          "Touch": "Open invoices",
          "Push": "Open invoices"
        }
      },
      "States": [
        {
          "Image": "imgs/money"
        }
      ]
    },
    {
      "UUID": "com.fahim.claude-duo.moneykey",
      "Name": "Invoice Key",
      "Tooltip": "One unpaid invoice per key (most overdue first) \u2014 press opens the invoices list",
      "Icon": "imgs/money",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/money"
        }
      ]
    }
  ]
}